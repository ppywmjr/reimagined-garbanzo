generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

enum BillingInterval {
  month
  year
}

enum SubscriptionStatus {
  active
  trialing
  past_due
  cancelled
  incomplete
  incomplete_expired
  unpaid
}

enum WebhookStatus {
  pending
  processed
  failed
}

model User {
  id               String         @id @default(uuid()) @db.Uuid
  clerkUserId      String         @unique @map("clerk_user_id")
  email            String         @map("email")
  displayName      String?        @map("display_name")
  stripeCustomerId String?        @map("stripe_customer_id")
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  subscriptions    Subscription[]

  @@index([stripeCustomerId])
  @@map("users")
}

model Plan {
  id              String          @id @default(uuid()) @db.Uuid
  name            String
  stripeProductId String          @unique @map("stripe_product_id")
  stripePriceId   String          @unique @map("stripe_price_id")
  billingInterval BillingInterval @map("billing_interval")
  pricePence      Int             @map("price_pence")
  isActive        Boolean         @map("is_active")
  features        Json            @db.JsonB
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz
  subscriptions   Subscription[]

  @@map("plans")
}

model Subscription {
  id                   String             @id @default(uuid()) @db.Uuid
  userId               String             @map("user_id") @db.Uuid
  planId               String?            @map("plan_id") @db.Uuid
  stripeCustomerId     String             @map("stripe_customer_id")
  stripeSubscriptionId String             @unique @map("stripe_subscription_id")
  status               SubscriptionStatus
  currentPeriodStart   DateTime           @map("current_period_start") @db.Timestamptz
  currentPeriodEnd     DateTime           @map("current_period_end") @db.Timestamptz
  cancelledAt          DateTime?          @map("cancelled_at") @db.Timestamptz
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime           @updatedAt @map("updated_at") @db.Timestamptz
  user                 User               @relation(fields: [userId], references: [id])
  plan                 Plan?              @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

model WebhookEvent {
  id            String        @id @default(uuid()) @db.Uuid
  stripeEventId String        @unique @map("stripe_event_id")
  eventType     String        @map("event_type")
  payload       Json          @db.JsonB
  status        WebhookStatus
  processedAt   DateTime?     @map("processed_at") @db.Timestamptz
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz

  @@index([status])
  @@map("webhook_events")
}
