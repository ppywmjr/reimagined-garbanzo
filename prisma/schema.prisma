generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

enum BillingInterval {
  month
  year
}

enum SubscriptionStatus {
  active
  trialing
  past_due
  cancelled
  incomplete
  incomplete_expired
  unpaid
}

enum WebhookStatus {
  pending
  processed
  failed
}

model User {
  id               String         @id @default(uuid()) @db.Uuid
  clerkUserId      String         @unique @map("clerk_user_id")
  email            String         @unique
  displayName      String?        @map("display_name")
  stripeCustomerId String?        @map("stripe_customer_id")
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  subscriptions    Subscription[]
  videoProgress    UserVideoProgress[]

  @@index([email])
  @@index([clerkUserId])
  @@index([stripeCustomerId])
  @@map("users")
}

model Plan {
  id              String          @id @default(uuid()) @db.Uuid
  name            String
  description     String?
  isFree          Boolean         @default(false) @map("is_free")
  stripeProductId String?         @unique @map("stripe_product_id")
  stripePriceId   String?         @unique @map("stripe_price_id")
  billingInterval BillingInterval? @map("billing_interval")
  pricePence      Int?            @map("price_pence")
  isActive        Boolean         @default(true) @map("is_active")
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz
  deactivatedAt   DateTime?       @map("deactivated_at") @db.Timestamptz
  subscriptions   Subscription[]
  planCourses     PlanCourse[]

  @@map("plans")
}

model Course {
  id          String       @id @default(uuid()) @db.Uuid
  title       String
  description String?
  thumbnail   String?
  sortOrder   Int          @default(0) @map("sort_order")
  isPublished Boolean      @default(false) @map("is_published")
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  courseVideos CourseVideo[]
  planCourses  PlanCourse[]

  @@map("courses")
}

model PlanCourse {
  planId    String   @map("plan_id") @db.Uuid
  courseId  String   @map("course_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  plan      Plan     @relation(fields: [planId], references: [id])
  course    Course   @relation(fields: [courseId], references: [id])

  @@id([planId, courseId])
  @@map("plan_courses")
}

model Video {
  id            String              @id @default(uuid()) @db.Uuid
  title         String              @map("title")
  url           String              @map("url")
  thumbnail     String              @map("thumbnail")
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime            @updatedAt @map("updated_at") @db.Timestamptz
  userProgress  UserVideoProgress[]
  courseVideos  CourseVideo[]

  @@map("videos")
}

model CourseVideo {
  courseId  String   @map("course_id") @db.Uuid
  videoId   String   @map("video_id") @db.Uuid
  position  Int      @map("position")
  course    Course   @relation(fields: [courseId], references: [id])
  video     Video    @relation(fields: [videoId], references: [id])

  @@id([courseId, videoId])
  @@map("course_videos")
}

model UserVideoProgress {
  userId        String   @map("user_id") @db.Uuid
  videoId       String   @map("video_id") @db.Uuid
  watched       Boolean  @default(false) @map("watched")
  progressSecs  Int     @default(0) @map("progress_secs")
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz
  user          User     @relation(fields: [userId], references: [id])
  video         Video    @relation(fields: [videoId], references: [id])

  @@id([userId, videoId])
  @@map("user_video_progress")
}

model Subscription {
  id                   String              @id @default(uuid()) @db.Uuid
  userId               String              @map("user_id") @db.Uuid
  planId               String              @map("plan_id") @db.Uuid
  stripeCustomerId     String?             @map("stripe_customer_id")
  stripeSubscriptionId String?             @unique @map("stripe_subscription_id")
  status               SubscriptionStatus  @default(active)
  currentPeriodStart   DateTime?           @map("current_period_start") @db.Timestamptz
  currentPeriodEnd     DateTime?           @map("current_period_end") @db.Timestamptz
  cancelledAt          DateTime?           @map("cancelled_at") @db.Timestamptz
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime            @updatedAt @map("updated_at") @db.Timestamptz
  user                 User                @relation(fields: [userId], references: [id])
  plan                 Plan                @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

model WebhookEvent {
  id            String        @id @default(uuid()) @db.Uuid
  stripeEventId String        @unique @map("stripe_event_id")
  eventType     String        @map("event_type")
  payload       Json          @db.JsonB
  status        WebhookStatus
  processedAt   DateTime?     @map("processed_at") @db.Timestamptz
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz

  @@index([status])
  @@map("webhook_events")
}
